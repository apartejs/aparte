{
  "name": "@aparte/core",
  "version": "1.0.0",
  "description": "High-performance AI conversation engine - Zero-dependency Web Components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "@aparte-workspace/source": "./src/index.ts",
      "node": {
        "types": "./dist/index.node.d.ts",
        "default": "./dist/index.node.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "@aparte-workspace/source": "./src/styles/bundle.css",
      "default": "./dist/index.css"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b --emitDeclarationOnly --force && node scripts/clean-declarations.mjs && pnpm run analyze",
    "analyze": "cem analyze",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "web-components",
    "chat",
    "ai",
    "streaming",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apartejs/aparte.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/apartejs/aparte/issues"
  }
}
