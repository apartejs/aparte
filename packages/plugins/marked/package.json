{
  "name": "@aparte/plugin-marked",
  "version": "1.0.0",
  "description": "Markdown rendering for aparté via marked — register it as the one-shot Markdown provider.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@aparte-workspace/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b --emitDeclarationOnly --force",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@aparte/core": "workspace:*",
    "marked": ">=12"
  },
  "devDependencies": {
    "@aparte/core": "workspace:*",
    "marked": "^18.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "aparte",
    "plugin",
    "markdown",
    "marked"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apartejs/aparte.git",
    "directory": "packages/plugins/marked"
  },
  "bugs": {
    "url": "https://github.com/apartejs/aparte/issues"
  }
}
