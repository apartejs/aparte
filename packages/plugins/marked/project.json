{
    "name": "@aparte/plugin-marked",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/plugins/marked/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-script",
            "outputs": ["{projectRoot}/dist"],
            "options": { "script": "build" }
        },
        "test": {
            "executor": "@nx/vite:test",
            "outputs": ["{options.reportsDirectory}"],
            "options": {
                "reportsDirectory": "../../../coverage/packages/plugins/marked",
                "cwd": "packages/plugins/marked"
            }
        }
    }
}
