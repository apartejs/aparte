{
  "name": "@aparte/engine",
  "version": "0.2.0-alpha.0",
  "description": "Framework-agnostic AI agent loop (runStreamAgent) + parsers/orchestrator — zero runtime deps, headless (browser or Node).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@aparte-workspace/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b --emitDeclarationOnly --force",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@aparte/core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@aparte/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aparte/core": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "ai",
    "agent",
    "streaming",
    "llm",
    "agent-loop"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apartejs/aparte.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/apartejs/aparte/issues"
  }
}
