{
    "name": "@aparte/provider-ai-sdk",
    "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/providers/ai/ai-sdk/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-script",
            "outputs": ["{projectRoot}/dist"],
            "options": { "script": "build" }
        },
        "test": {
            "executor": "@nx/vite:test",
            "outputs": ["{options.reportsDirectory}"],
            "options": {
                "reportsDirectory": "../../../../coverage/packages/providers/ai/ai-sdk",
                "cwd": "packages/providers/ai/ai-sdk"
            }
        }
    }
}
