{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@aparte-workspace/source"],
    // Dev source paths are added per package as milestones land (M1: core, …).
    // Path aliases (when populated) resolve relative to this file — no root prefix option
    // is set (that one is deprecated in TS 7.0).
    "paths": {}
  }
}
